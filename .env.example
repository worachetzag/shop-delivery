# คัดลอกเป็นไฟล์ชื่อ ".env" ที่รากโปรเจ็กต์ shop-delivery (ข้างๆ โฟลเดอร์ shop_delivery)
# cp .env.example .env   แล้วแก้ค่าจริง — อย่า commit .env

# --- Neon PostgreSQL (คัดลอก URI จาก Neon Console → Connection string) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

DEBUG=True
SECRET_KEY=เปลี่ยนเป็นค่าสุ่มยาวๆ

# ถ้ารัน migrate / runserver จากเครื่องและใช้ Neon อย่างเดียว — ไม่ต้องใส่ sqlite

# LINE: แจ้งเตือนออเดอร์ — LIFF Endpoint ถ้าจบด้วย .../customer/ ให้ใช้ค่า default orders (ดีลิงก์เป็น .../orders/<id>)
# LINE_LIFF_ORDER_URI_PREFIX=customer/orders
