# (ใช้ไฟล์ .env.example / .env ที่ราก repo — Django โหลดอัตโนมัติจาก shop-delivery/.env)
#
# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Neon ใส่แบบ URI (เหมือนใน Render)
# DATABASE_URL=postgresql://...@....neon.tech/neondb?sslmode=require
DATABASE_URL=sqlite:///db.sqlite3

# LINE Bot Configuration
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_LIFF_ID=your-liff-id

# Payment Gateway Configuration
PROMPTPAY_MERCHANT_ID=your-promptpay-merchant-id
PROMPTPAY_API_KEY=your-promptpay-api-key
PROMPTPAY_WEBHOOK_SECRET=your-promptpay-webhook-secret

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://liff.line.me

# Media Files
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Static Files
STATIC_URL=/static/
STATIC_ROOT=staticfiles/

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# --- Deploy (Render + Neon + Pages แยกโดเมน) ---
# DATABASE_URL=postgresql://...@...neon.tech/neondb?sslmode=require
# DEBUG=False
# ALLOWED_HOSTS_EXTRA=my-api.onrender.com
# FRONTEND_URL=https://xxxx.pages.dev
# CORS_ALLOWED_ORIGINS_EXTRA=https://xxxx.pages.dev
# CSRF_TRUSTED_ORIGINS_EXTRA=https://xxxx.pages.dev
# NGROK_CROSS_SITE_COOKIES=True
# RESET_DB_ON_START=0
# SEED_DEMO_ON_START=0
# PRESERVE_STORE_SETTINGS_ON_RESET=1
# PRESERVE_STAFF_USERS_ON_RESET=1
