# Frontend Environment Variables
REACT_APP_API_BASE_URL=http://127.0.0.1:8000/api/
REACT_APP_LIFF_ID=your-liff-id
REACT_APP_LINE_CHANNEL_ID=your-channel-id
REACT_APP_ENVIRONMENT=development

# LINE LIFF Configuration
REACT_APP_LIFF_ENDPOINT_URL=https://yourdomain.com/liff/
REACT_APP_LIFF_SCOPE=profile,openid

# API Configuration
REACT_APP_API_TIMEOUT=10000
REACT_APP_API_RETRY_ATTEMPTS=3

# Feature Flags
REACT_APP_ENABLE_PAYMENT=true
REACT_APP_ENABLE_TRACKING=true
REACT_APP_ENABLE_NOTIFICATIONS=true



